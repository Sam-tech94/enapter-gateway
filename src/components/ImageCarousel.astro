---
import ArrowForward from "./imageComponents/ArrowForward.astro";
import ArrowBack from "./imageComponents/ArrowBack.astro";
---

<div class="flex flex-col items-center w-full max-w-[1000px] mx-auto">
  <!-- Carousel with external arrows -->
  <div class="flex items-center w-full relative">
    <!-- Prev Button -->
    <button
      id="prev"
      class="hidden md:flex flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white border border-border shadow items-center justify-center hover:border-borderHover hover:transition-colors mr-2 sm:mr-4 md:mr-6"
      aria-label="Previous slide"
    >
      <ArrowBack />
    </button>

    <!-- Slides -->
    <div
      class="flex-1 overflow-hidden border border-divider2 rounded-md shadow-lg"
    >
      <div id="carousel" class="flex transition-transform duration-500">
        <img
          src="/screen-1.png"
          class="w-full object-contain cursor-zoom-in"
          alt="Slide 1"
        />
        <img
          src="/screen-2.png"
          class="w-full object-contain cursor-zoom-in"
          alt="Slide 2"
        />
        <img
          src="/screen-3.png"
          class="w-full object-contain cursor-zoom-in"
          alt="Slide 3"
        />
        <img
          src="/screen-4.png"
          class="w-full object-contain cursor-zoom-in"
          alt="Slide 4"
        />
        <img
          src="/screen-5.png"
          class="w-full object-contain cursor-zoom-in"
          alt="Slide 5"
        />
        <img
          src="/screen-6.png"
          class="w-full object-contain cursor-zoom-in"
          alt="Slide 6"
        />
        <img
          src="/screen-7.png"
          class="w-full object-contain cursor-zoom-in"
          alt="Slide 7"
        />
        <img
          src="/screen-8.png"
          class="w-full object-contain cursor-zoom-in"
          alt="Slide 8"
        />
      </div>
    </div>

    <!-- Next Button -->
    <button
      id="next"
      class="hidden md:flex flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white border border-border shadow items-center justify-center hover:border-borderHover hover:transition-colors ml-2 sm:ml-4 md:ml-6"
      aria-label="Next slide"
    >
      <ArrowForward />
    </button>
  </div>

  <!-- Pagination -->
  <div id="dots" class="flex justify-center mt-8 space-x-2"></div>
</div>

<!-- Popup Modal with Overlay -->
<div
  id="imageModal"
  class="hidden fixed inset-0 z-50 bg-[rgba(0,0,0,0.6)] items-center justify-center"
  aria-modal="true"
  role="dialog"
>
  <div
    id="modalContent"
    class="relative mx-4 bg-background2 max-w-6xl rounded-xl p-6 flex justify-center"
  >
    <button id="closeModal" type="button">
      <span
        class="material-symbols-outlined text-textGray font-bold text-sm absolute top-2 right-2 cursor-pointer hover:text-textGrayHover active:text-textGrayActive transition"
        >close</span
      >
    </button>
    <img
      id="modalImage"
      alt="Enlarged image"
      class="max-w-full max-h-[80vh] object-contain rounded-lg"
    />
  </div>
</div>

<script type="module">
  const carousel = document.getElementById("carousel");
  const slides = carousel.children.length;
  let current = 0;

  const dotsContainer = document.getElementById("dots");
  const prevBtn = document.getElementById("prev");
  const nextBtn = document.getElementById("next");

  const modal = document.getElementById("imageModal");
  const modalImage = document.getElementById("modalImage");
  const closeModal = document.getElementById("closeModal");
  const modalContent = document.getElementById("modalContent");

  // Generate dots
  for (let i = 0; i < slides; i++) {
    const dot = document.createElement("button");
    dot.className = "w-2 h-2 rounded-full bg-backgroundObject";
    dot.addEventListener("click", () => goToSlide(i));
    dotsContainer.appendChild(dot);
  }

  const updateCarousel = () => {
    carousel.style.transform = `translateX(-${current * 100}%)`;
    [...dotsContainer.children].forEach((dot, i) => {
      dot.className = `w-2 h-2 rounded-full ${i === current ? "bg-blue" : "bg-backgroundObject"}`;
    });
  };

  const goToSlide = (index) => {
    current = index;
    updateCarousel();
  };

  prevBtn.addEventListener("click", () => {
    current = current === 0 ? slides - 1 : current - 1;
    updateCarousel();
    resetAutoSlide();
  });

  nextBtn.addEventListener("click", () => {
    current = current === slides - 1 ? 0 : current + 1;
    updateCarousel();
    resetAutoSlide();
  });

  // Auto-slide every 5 seconds
  let autoSlideInterval = setInterval(() => {
    current = (current + 1) % slides;
    updateCarousel();
  }, 5000);

  const resetAutoSlide = () => {
    clearInterval(autoSlideInterval);
    autoSlideInterval = setInterval(() => {
      current = (current + 1) % slides;
      updateCarousel();
    }, 5000);
  };

  // Swipe support
  let startX = 0,
    endX = 0;
  carousel.addEventListener(
    "touchstart",
    (e) => (startX = e.touches[0].clientX)
  );
  carousel.addEventListener("touchmove", (e) => (endX = e.touches[0].clientX));
  carousel.addEventListener("touchend", () => {
    if (startX - endX > 50) nextBtn.click();
    else if (endX - startX > 50) prevBtn.click();
  });

  updateCarousel();

  // Popup Modal logic
  document.querySelectorAll("#carousel img").forEach((img) => {
    img.addEventListener("click", () => {
      modalImage.src = img.src;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.classList.add("overflow-hidden");
    });
  });

  const hideModal = () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.classList.remove("overflow-hidden");
  };

  closeModal.addEventListener("click", hideModal);

  modal.addEventListener("click", (e) => {
    if (!modalContent.contains(e.target)) hideModal();
  });

  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape") hideModal();
  });
</script>
