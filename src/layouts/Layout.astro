---
import "@enapter/design-tokens/colors.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Cookies from "../components/Cookies.astro";

export interface Props {
  title: string;
}

const { title }: Props = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });

        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s) as HTMLScriptElement,
          dl = l != "dataLayer" ? "&l=" + l : "";

        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-5P6CB5CP");
    </script>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Enapter Gateway is an advanced local-first central automation controller of energy systems powered with open-source software. It provides real-time device communication, monitoring and control, performance analytics, and system diagnostics, helping to optimize energy infrastructure and energy efficiency. A powerful bundle of low-code Lua scripting runtime, MQTT, OPC UA, and REST API interfaces opens endless possibilities for artificial intelligence optimizations and 3rd party integrations."
    />
    <meta name="viewport" content="width=device-width" />
    <!-- Keywords (optional but helpful for some crawlers) -->
    <meta name="keywords" content="Enapter Gateway, Energy Management System, Local-first energy control, Open-source energy software, MQTT energy integration, REST API energy systems, Low-code energy automation, AI energy optimization">

    <!-- Open Graph / Facebook Meta Tags -->
    <meta property="og:url" content="https://fw.enapter.com/" />
    <meta property="og:domain" content="fw.enapter.com" />
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Enapter Gateway – local-first central automation controller for energy systems"
    />
    <meta
      property="og:description"
      content="Enhance your energy system with the Enapter Gateway - a local-first central automation controller powered with open-source software. It provides real-time device communication, monitoring and control, performance analytics, and system diagnostics, helping to balance energy infrastructure and energy efficiency. A powerful bundle of low-code Lua scripting runtime, MQTT, OPC UA, and REST API interfaces opens endless possibilities for artificial intelligence optimizations and 3rd party integrations."
    />
    <meta property="og:image" content="https://fw.enapter.com/gateway.png" />
    <meta property="og:image:alt" content="Enapter Gateway Software" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Enapter Gateway Software" />
    <meta property="og:logo" content="https://fw.enapter.com/logo.png" />
    

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="fw.enapter.com" />
    <meta property="twitter:url" content="https://fw.enapter.com/" />
    <meta
      name="twitter:title"
      content="Enapter Gateway – local-first central automation controller for energy systems"
    />
    <meta
      name="twitter:description"
      content="Enhance your energy system with the Enapter Gateway - a local-first central automation controller powered with open-source software. It provides real-time device communication, monitoring and control, performance analytics, and system diagnostics, helping to balance energy infrastructure and energy efficiency. A powerful bundle of low-code Lua scripting runtime, MQTT, OPC UA, and REST API interfaces opens endless possibilities for artificial intelligence optimizations and 3rd party integrations."
    />
    <meta name="twitter:image" content="https://fw.enapter.com/gateway.png" />
    <meta name="twitter:image:alt" content="Enapter Gateway Software" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined&display=block"
      rel="stylesheet"
    />
     <!-- Canonical URL (important for SEO) -->
    <link rel="canonical" href="https://fw.enapter.com/" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      html,
      body {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
          "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji",
          "Segoe UI Symbol", "Noto Color Emoji";
      }
    </style>
  </head>
  <body
    class="bg-background2 min-h-[100dvh] flex flex-col px-4 md:px-8 lg:max-w-7xl mx-auto"
  >
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-5P6CB5CP"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <Header />
    <slot />
    <Footer />
    <Cookies />
  </body>
</html>
